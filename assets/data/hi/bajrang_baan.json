{
    "id": "bajrang_baan",
    "title": "बजरंग बाण",
    "content": [
        "दोहा",
        "निश्चय प्रेम प्रतीति ते, विनय करैं सनमान।",
        "तेहि के कारज सकल शुभ, सिद्ध करैं हनुमान॥",
        "चौपाई",
        "जय हनुमंत संत हितकारी।",
        "सुन लीजै प्रभु अरज हमारी॥",
        "जन के काज विलंब न कीजै।",
        "आतुर दौड़ि महा सुख दीजै॥",
        "जैसे कूदि सिंधु महि पारा।",
        "सुरसा बदन पैठि विस्तारा॥",
        "आगे जाय लंकिनी रोका।",
        "मारेहु लात गई सुरलोका॥",
        "जाय विभीषण को सुख दीन्हा।",
        "सीता निरखि परम पद लीन्हा॥",
        "बाग उजाड़ि सिंधु महं बोरा।",
        "अति आतुर जमकातर तोरा॥",
        "अक्षय कुमार मारि संहारा।",
        "लूम लपेटि लंक को जारा॥",
        "लाह समान लंक जरि गई।",
        "जय जय धुनि सुरपुर महं भई॥",
        "अब विलंब केहि कारण स्वामी।",
        "कृपा करहु उर अंतर्यामी॥",
        "जय जय लक्ष्मण प्राण के दाता।",
        "आतुर होइ दुख करहु निपाता॥",
        "जय गिरिधर जय जय सुखसागर।",
        "सुर समूह समरथ भटनागर॥",
        "ॐ हनु हनु हनु हनुमंत हठीले।",
        "बैरीहि मारु बज्र सम कीले॥",
        "गदा बज्र लै बैरिहिं मारो।",
        "महाराज निज दास उबारो॥",
        "ॐ ह्रीं ह्रीं ह्रीं हनुमंत कपीसा।",
        "ॐ हुं हुं हुं हनु अरि उर सीसा॥",
        "सत्य होहु हरि सत्य पाय के।",
        "रामदूत धरु मारु धाय के॥",
        "जय हनुमंत अनंत अगाधा।",
        "दुख पावत जन केहि अपराधा॥",
        "पूजा जप तप नेम अचारा।",
        "नहिं जानत हौं दास तुम्हारा॥",
        "वन उपवन जल थल गृह माहीं।",
        "तुम्हरे बल हम डरपत नाहीं॥",
        "पाय परौं कर जोरि मनावौं।",
        "यहि अवसर अब केहि गोहरावौं॥",
        "जय अंजनि कुमार बलवंता।",
        "शंकर सुवन वीर हनुमंता॥",
        "बदन कराल काल कुल घालक।",
        "राम सहाय सदा प्रतिपालक॥",
        "भूत प्रेत पिशाच निशाचर।",
        "अग्नि बैताल काल मरिचर॥",
        "इनहिं मारु तोहि शपथ राम की।",
        "राखु नाथ मर्यादा नाम की॥",
        "जनकसुता हरि दास कहावो।",
        "ताकी शपथ विलंब न लावो॥",
        "जय जय जय धुनि होत अकाशा।",
        "सुमिरत होत दुखों का नाशा॥",
        "उठु उठु चलु तोहि राम दुहाई।",
        "पाय परौं कर जोरि मनाई॥",
        "ॐ चं चं चं चं चपल चलंता।",
        "ॐ हनु हनु हनु हनुमंता॥",
        "ॐ सं सं सं समरथ बलवाना।",
        "ॐ हनुमंत बलवंत सुजाना॥",
        "अपने जन को कष्ट न देहू।",
        "सुमिरत होय आनंद सनेहू॥",
        "ताते विनय करौं पुनि भारी।",
        "हरहु सकल दुख विपति हमारी॥",
        "ऐसो बल प्रभु तुम्हरो तोरा।",
        "कस न हरहु दुख संकट मोरा॥",
        "हे बजरंग बाण सम धावो।",
        "मेरे संकट दूर भगावो॥",
        "जय जय जय हनुमाना।",
        "जय जय जय गुण ज्ञान निधाना॥",
        "अंतिम दोहा",
        "प्रेम प्रतीति हनुमत भजै, सदा धरै उर ध्यान।",
        "तेहि के कारज तुरत ही, सिद्ध करैं हनुमान॥"
    ]
}